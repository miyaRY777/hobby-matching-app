<div class="w-full max-w-7xl mx-auto flex flex-col gap-6">
  <h1 class="text-2xl font-semibold text-gray-800">プロフィール一覧</h1>
  <%= link_to "共有リンク管理", mypage_rooms_path, class: "text-blue-600 hover:underline text-sm font-medium" %>

  <!-- 検索フォーム -->
  <div class="w-full rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
    <%= render "search_form" %>
  </div>

  <!-- カードグリッド：4列 -->
  <%= render "profile_list", profiles: @profiles %>
</div>
