{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)"
    ],
    "deny": [
      "Bash(sudo *)",

      "Bash(git reset *)",
      "Bash(git reset --hard *)",
      "Bash(git rebase *)",
      "Bash(git clean *)",
      "Bash(git branch -D *)",

      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./config/master.key)",
      "Read(./config/credentials.yml.enc)",
      "Read(./id_rsa)",
      "Read(./id_ed25519)",
      "Read(./**/*.pem)",

      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./**/secrets/**)",

      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(psql *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "if echo \"$CLAUDE_TOOL_INPUT\" | jq -r '.command' | grep -qE 'rm\\s+-rf'; then echo 'rm -rf は禁止です。個別に rm を使ってください。' >&2; exit 2; fi"
        }]
      },
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "if echo \"$CLAUDE_TOOL_INPUT\" | jq -r '.command' | grep -qE 'git\\s+push.*\\b(main|master)\\b'; then echo 'mainへの直接pushは禁止です。PRを使ってください。' >&2; exit 2; fi"
        }]
      }
    ]
  }
}
